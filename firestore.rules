rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // For this app, we'll allow unverified for now but the rule engine check is good
      return isSignedIn();
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'btechtools.ng@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Schemas ---
    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.username is string
        && data.email is string
        && data.role in ['user', 'admin'];
    }

    function isValidInvestment(data) {
      return data.userId == request.auth.uid
        && data.amount is number && data.amount > 0
        && data.status in ['running', 'completed'];
    }

    function isValidDeposit(data) {
      return data.userId == request.auth.uid
        && data.amount is number && data.amount >= 50
        && data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidWithdrawal(data) {
      return data.userId == request.auth.uid
        && data.amount is number && data.amount >= 50
        && data.bankDetails is string && data.bankDetails.size() < 1000
        && data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidInvestmentPlan(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.minAmount is number && data.minAmount >= 0
        && data.maxAmount is number && data.maxAmount >= data.minAmount
        && (data.profitPercent is number || data.returnPercent is number)
        && (
          (data.durationHours is number && data.durationHours > 0) ||
          (data.durationDays is number && data.durationDays > 0)
        );
    }

    function isValidLoanApplication(data) {
      return data.userId == request.auth.uid
        && data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 200
        && data.bankName is string && data.bankName.size() > 0 && data.bankName.size() < 100
        && data.accountNumber is string && data.accountNumber.size() > 0 && data.accountNumber.size() < 100
        && data.amountRequested is number && data.amountRequested > 0
        && data.status in ['pending', 'approved', 'rejected', 'processing'];
    }

    // --- Collection Rules ---

    // Users
    match /users/{userId} {
      // Allow reading single user, admin read all, or anyone checking their own profile
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && (
        resource.data.referredByUid == request.auth.uid ||
        request.query.limit == 1
      ));
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'user' && incoming().balance == 0;
      allow update: if (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['balance', 'totalEarnings', 'role', 'status'])) || (
        isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['username', 'balance', 'totalEarnings', 'phoneNumber', 'fcmToken', 'lastTokenSync'])
      ) || (
        // Referral bonus logic: allow a new user to update their referrer's balance
        isSignedIn() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'totalEarnings']) &&
        incoming().balance == existing().get('balance', 0) + get(/databases/$(database)/documents/settings/global).data.referralBonus &&
        incoming().totalEarnings == existing().get('totalEarnings', 0) + get(/databases/$(database)/documents/settings/global).data.referralBonus &&
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.referredByUid == userId
      );
    }

    // Investments
    match /investments/{invId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidInvestment(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
    }

    // Deposits
    match /deposits/{depId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidDeposit(incoming());
      allow update: if isAdmin();
    }

    // Withdrawals
    match /withdrawals/{witId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidWithdrawal(incoming());
      allow update: if isAdmin();
    }

    function whereUserId() {
      return resource.data.userId;
    }

    // Chats
    match /chats/{chatId} {
      allow read: if isOwner(chatId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(chatId) || isAdmin();
      
      match /messages/{msgId} {
        allow read, list: if isOwner(chatId) || isAdmin();
        allow create: if (isOwner(chatId) && (!('isAdmin' in incoming()) || incoming().isAdmin == false)) || isAdmin();
      }
    }

    // Settings
    match /settings/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Loan Applications
    match /loanApplications/{loanId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && isValidLoanApplication(incoming());
      allow update: if isAdmin();
    }
    
    // Investment Plans (admin configurable)
    match /investment_plans/{planId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() && isValidInvestmentPlan(incoming());
      allow delete: if isAdmin();
    }
  }
}
